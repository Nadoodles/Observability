# ── Observability Platform — Environment Variables ────────────────────────────
# Copy this file to .env and fill in values for local overrides.
# Docker Compose reads .env automatically from the project root.
# Services read individual vars from their environment blocks in compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=observability
POSTGRES_USER=obs_user
POSTGRES_PASSWORD=obs_pass

# ── Shared connection strings ─────────────────────────────────────────────────
# Used when running services outside Docker (e.g. bare metal dev)
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://obs_user:obs_pass@localhost:5432/observability

# ── Ingestion Service ─────────────────────────────────────────────────────────
REDIS_CHANNEL=ad_events
SIMULATE=true
SIMULATOR_RATE=20          # events per second

# ── Processing Service ────────────────────────────────────────────────────────
FLUSH_INTERVAL=30          # aggregation window in seconds

# ── Alert Service ─────────────────────────────────────────────────────────────
POLL_INTERVAL=30           # how often to evaluate SLA thresholds (seconds)
LATENCY_WARN_MS=150        # avg latency WARNING threshold
LATENCY_CRIT_MS=300        # avg latency CRITICAL threshold
ERROR_RATE_WARN=0.005      # 0.5%  error rate WARNING threshold
ERROR_RATE_CRIT=0.02       # 2.0%  error rate CRITICAL threshold

# ── React Frontend ────────────────────────────────────────────────────────────
# Set VITE_ALERTS_URL to your deployed alerts service URL for production builds.
# For local dev (npm run dev), localhost:8003 is used automatically.
VITE_ALERTS_URL=http://localhost:8003
